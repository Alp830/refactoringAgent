using UnityEngine;

public class Door : MonoBehaviour
{
    public bool isOpen;
    public bool isClosed;
    public bool isLocked;
    public bool isOpening;

    public void Interact()
    {
        if (isLocked)
        {
            Debug.Log("Door is locked");
            return;
        }

        if (isClosed)
        {
            isOpening = true;
            isClosed = false;
        }
    }
}