using UnityEngine;

public class Weapon : MonoBehaviour
{
    public bool isSingleFire;
    public bool isBurstFire;
    public bool isAutoFire;

    public void Fire()
    {
        if (isSingleFire)
            Debug.Log("Single shot fired");

        if (isBurstFire)
            Debug.Log("Burst fire");

        if (isAutoFire)
            Debug.Log("Automatic fire");
    }
}